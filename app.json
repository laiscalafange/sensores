{
  "expo": {
    "name": "sensores",
    "slug": "sensores",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "sensores",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true
    },
    
    
    "android": {
      "edgeToEdgeEnabled": true
    },

    "plugins": ["expo-router"],

    "experiments": {
      "typedRoutes": true
    }
  }
}